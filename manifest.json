{
  "manifest_version": 3,
  "name": "雪哨",
  "version": "1.3.0",
  "description": "雪哨：监控雪球特别关注分组新帖，本机通知+常驻小窗+可选推送到微信。",
  "author": {
    "email": "cheung.cn@gmail.com",
    "url": "https://github.com/JohnWish1590/xueqiu-watch"
  },
  "permissions": ["alarms", "notifications", "storage", "offscreen", "windows", "tabs", "scripting", "system.display"],
  "host_permissions": ["https://xueqiu.com/*", "https://*.xueqiu.com/*", "https://qyapi.weixin.qq.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://xueqiu.com/*", "https://*.xueqiu.com/*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "雪哨",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
